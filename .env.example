# Server
PORT=3001
NODE_ENV=development

# Music library paths (comma-separated)
MUSIC_LIBRARY_PATHS=/mnt/nas/music

# Database
DATABASE_PATH=./data/audioserver.db

# Auth (generate a random secret: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# Known DLNA/UPnP devices to probe directly (fallback when SSDP is blocked)
# Comma-separated host:port pairs
# DLNA_DEVICES=192.168.2.42:49152,192.168.2.27:1400

# Tidal (future)
# TIDAL_CLIENT_ID=
# TIDAL_CLIENT_SECRET=

# Spotify (future)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
